<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>MoonAI Profiler Report</title>
  <style>
    :root {
      --bg: #f5f7fb;
      --paper: #ffffff;
      --ink: #182230;
      --muted: #5b6b7f;
      --line: #d7dee9;
      --accent: #1d4ed8;
      --accent-soft: #dbeafe;
      --shadow: 0 18px 40px rgba(24, 34, 48, 0.08);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Segoe UI", "Helvetica Neue", sans-serif;
      background: linear-gradient(180deg, #edf2ff 0%, var(--bg) 100%);
      color: var(--ink);
    }
    .page {
      width: min(1280px, calc(100vw - 32px));
      margin: 24px auto 48px;
      display: grid;
      grid-template-columns: 280px minmax(0, 1fr);
      gap: 24px;
      align-items: start;
    }
    .sidebar, .panel {
      background: rgba(255,255,255,0.92);
      border: 1px solid var(--line);
      border-radius: 20px;
      box-shadow: var(--shadow);
    }
    .sidebar {
      position: sticky;
      top: 20px;
      padding: 20px;
      backdrop-filter: blur(10px);
    }
    .content { display: grid; gap: 20px; }
    .panel { padding: 24px; }
    h1, h2, h3 { margin: 0 0 12px; line-height: 1.15; }
    h1 { font-size: 2.1rem; }
    h2 { font-size: 1.35rem; color: var(--accent); }
    h3 { font-size: 1rem; }
    .muted { color: var(--muted); }
    .stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 12px;
    }
    .stat {
      padding: 14px 16px;
      border-radius: 16px;
      background: var(--accent-soft);
      border: 1px solid #bfdbfe;
    }
    .stat strong { display: block; font-size: 1.2rem; }
    .toc ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 8px; }
    .toc a { color: var(--accent); text-decoration: none; }
    .toc a:hover { text-decoration: underline; }
    table { width: 100%; border-collapse: collapse; background: white; }
    th, td {
      padding: 10px 12px;
      border-bottom: 1px solid #e6ebf2;
      text-align: left;
      vertical-align: top;
      font-size: 0.93rem;
    }
    th { background: #eef4ff; color: var(--accent); }
    .chart-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 18px;
    }
    figure {
      margin: 0;
      padding: 16px;
      border: 1px solid var(--line);
      border-radius: 16px;
      background: white;
    }
    img { width: 100%; border-radius: 10px; }
    figcaption { margin-top: 10px; color: var(--muted); font-size: 0.9rem; }
    details {
      border: 1px solid var(--line);
      border-radius: 16px;
      background: #fcfdff;
      overflow: hidden;
    }
    details + details { margin-top: 14px; }
    summary {
      cursor: pointer;
      list-style: none;
      padding: 18px 20px;
      background: linear-gradient(90deg, rgba(29,78,216,0.10), rgba(29,78,216,0.03));
      font-weight: 700;
    }
    summary::-webkit-details-marker { display: none; }
    .details-body { padding: 18px; display: grid; gap: 18px; }
    .meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      color: var(--muted);
      font-size: 0.92rem;
    }
    .pill {
      padding: 6px 10px;
      border-radius: 999px;
      background: var(--accent-soft);
      border: 1px solid #bfdbfe;
    }
    .empty {
      padding: 16px;
      border-radius: 16px;
      border: 1px dashed var(--line);
      color: var(--muted);
      background: #f8fbff;
    }
    @media (max-width: 980px) {
      .page { grid-template-columns: 1fr; }
      .sidebar { position: static; }
    }
  </style>
</head>
<body>
  <div class="page">
    <aside class="sidebar">
      <div class="toc">
        <h3>Contents</h3>
        <ul>
          <li><a href="#overview">Overview</a></li>
          <li><a href="#summary">Run Summary</a></li>
          <li><a href="#comparisons">Comparisons</a></li>
          <li><a href="#runs">Profiles</a></li>
          <li><a href="#skipped">Skipped</a></li>
        </ul>
      </div>
    </aside>

    <main class="content">
      <section class="panel" id="overview">
        <h1>MoonAI Profiler Report</h1>
        <p class="muted">{{ report_name }} · generated {{ generated_at }}</p>
        <div class="stats">
          <div class="stat"><span class="muted">Input directory</span><strong>{{ input_dir }}</strong></div>
          <div class="stat"><span class="muted">Analysed runs</span><strong>{{ run_count }}</strong></div>
          <div class="stat"><span class="muted">Skipped</span><strong>{{ skipped_count }}</strong></div>
        </div>
      </section>

      <section class="panel" id="summary">
        <h2>Run Summary</h2>
        <table>
          <thead>
            <tr>
              <th>Run</th>
              <th>Generations</th>
              <th>Avg Generation Ms</th>
              <th>Top Event</th>
              <th>Top Event Avg Ms/Active Gen</th>
              <th>Path</th>
            </tr>
          </thead>
          <tbody>
            {% for row in summary_rows %}
            <tr>
              <td>{{ row.label }}</td>
              <td>{{ row.generations }}</td>
              <td>{{ row.avg_generation_ms }}</td>
              <td>{{ row.top_event }} ({{ row.top_event_nonzero_generation_count }} active)</td>
              <td>{{ row.top_event_avg_ms }}</td>
              <td>{{ row.path }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </section>

      <section class="panel" id="comparisons">
        <h2>Cross-Run Comparisons</h2>
        <div class="chart-grid">
          {% for chart in comparison_charts %}
          <figure>
            <h3>{{ chart.title }}</h3>
            <img src="{{ chart.image_uri }}" alt="{{ chart.title }} chart">
            <figcaption>{{ chart.caption }}</figcaption>
          </figure>
          {% endfor %}
        </div>
      </section>

      <section class="panel" id="runs">
        <h2>Profiles</h2>
        {% for run in run_sections %}
        <details {% if loop.first %}open{% endif %}>
          <summary>{{ run.label }}</summary>
          <div class="details-body">
            <div class="meta">
              <span class="pill">Run dir: {{ run.name }}</span>
              <span class="pill">Mode: {{ run.mode }}</span>
              <span class="pill">Generations: {{ run.generation_count }}</span>
              <span class="pill">Avg generation: {{ run.avg_generation_ms }} ms</span>
              <span class="pill">Top event: {{ run.top_event_name }} ({{ run.top_event_avg_ms }} ms/active gen)</span>
              <span class="pill">Top event active generations: {{ run.top_event_nonzero_generation_count }}</span>
              <span class="pill">Top event total time: {{ run.top_event_total_ms }} ms</span>
            </div>

            {% if run.summary_meta.path_count_note %}
            <div class="empty">{{ run.summary_meta.path_count_note }}</div>
            {% endif %}

            {% if run.run_notes %}
            <div>
              <h3>Profiler Notes</h3>
              <table>
                <tbody>
                  {% for note in run.run_notes %}
                  <tr>
                    <td>{{ note }}</td>
                  </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
            {% endif %}

            <div class="chart-grid">
              {% for chart in run.charts %}
              <figure>
                <h3>{{ chart.title }}</h3>
                <img src="{{ chart.image_uri }}" alt="{{ chart.title }} chart">
                <figcaption>{{ chart.caption }}</figcaption>
              </figure>
              {% endfor %}
            </div>

            <div>
              <h3>Run Metadata</h3>
              <table>
                <tbody>
                  {% for key, value in run.run_meta.items() %}
                  <tr>
                    <th>{{ key }}</th>
                    <td>{{ value }}</td>
                  </tr>
                  {% endfor %}
                  <tr>
                    <th>profile_path</th>
                    <td>{{ run.path }}</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div>
              <h3>Summary Events</h3>
              <table>
                <thead>
                  <tr>
                    <th>Event</th>
                    <th>Total Ms</th>
                    <th>Avg / Generation</th>
                    <th>Nonzero Generations</th>
                    <th>Avg / Nonzero Generation</th>
                  </tr>
                </thead>
                <tbody>
                  {% for row in run.summary_events %}
                  <tr>
                    <td>{{ row.name }}</td>
                    <td>{{ row.total_ms }}</td>
                    <td>{{ row.avg_ms_per_generation }}</td>
                    <td>{{ row.nonzero_generation_count }}</td>
                    <td>{{ row.avg_ms_per_nonzero_generation }}</td>
                  </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>

            <div>
              <h3>Summary Counters</h3>
              <table>
                <thead>
                  <tr>
                    <th>Counter</th>
                    <th>Total</th>
                    <th>Avg / Generation</th>
                    <th>Nonzero Generations</th>
                    <th>Avg / Nonzero Generation</th>
                  </tr>
                </thead>
                <tbody>
                  {% for row in run.summary_counters %}
                  <tr>
                    <td>{{ row.name }}</td>
                    <td>{{ row.total }}</td>
                    <td>{{ row.avg_per_generation }}</td>
                    <td>{{ row.nonzero_generation_count }}</td>
                    <td>{{ row.avg_per_nonzero_generation }}</td>
                  </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </div>
        </details>
        {% endfor %}
      </section>

      <section class="panel" id="skipped">
        <h2>Skipped Profiles</h2>
        {% if skipped_profiles %}
        <table>
          <thead>
            <tr><th>Name</th><th>Reason</th></tr>
          </thead>
          <tbody>
            {% for skipped in skipped_profiles %}
            <tr>
              <td>{{ skipped.name }}</td>
              <td>{{ skipped.reason }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
        {% else %}
        <div class="empty">No skipped profiles.</div>
        {% endif %}
      </section>
    </main>
  </div>
</body>
</html>
